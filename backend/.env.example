# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Allowed browser origins for CORS (comma-separated). Add the Vaishnavi Group
# website domain(s) here so the site can call this API from the browser.
# Example: https://www.vaishnavigroup.in,https://vaishnavigroup.in,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/helpdesk?schema=public"

# JWT — generate two DIFFERENT random secrets (min 32 chars) for production.
# Generate with:  openssl rand -base64 48
# In production the server refuses to start if these are weak/default/identical.
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP) — required for signup OTP + password-reset emails to actually send.
# If SMTP_HOST is left blank, emails are skipped and the OTP is printed to the
# backend log instead (handy for local testing).
#
# SendGrid example (recommended — SMTP_USER is the literal word "apikey"):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxxxx   (your SendGrid API key)
#   SMTP_FROM="Your Company <noreply@yourdomain.com>"   (must be a verified sender / authenticated domain)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Help Desk <support@helpdesk.com>"

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Frontend reset password URL base
RESET_PASSWORD_URL=http://localhost:5173/reset-password
